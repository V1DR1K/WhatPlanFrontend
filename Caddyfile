:80 {
  encode zstd gzip

  @assets path /assets/*
  header @assets {
    Cache-Control "public, max-age=31536000, immutable"
  }

  header /index.html {
    Cache-Control "no-cache, no-store, must-revalidate"
  }

  route {
    handle /api/* {
      reverse_proxy whatplan-backend:8080
    }
    handle {
      root * /srv
      try_files {path} /index.html
      file_server
    }
  }
}
